    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "expo": "~55.0.5",
    "expo-asset": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-modules-core": "~55.0.14",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
